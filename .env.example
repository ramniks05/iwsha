# Local dev (XAMPP) — use Vite proxy so session cookies work:
VITE_API_BASE_URL=/api

# Production on Vercel (www.iwshatrust.org) — same-origin /api proxy:
# VITE_API_BASE_URL=/api
# BACKEND_API_URL=https://hrntechsolutions.com/iwsha-backend/api  (Vercel env var)

# Direct cross-origin URL (only if frontend + backend share cookie domain):
# VITE_API_BASE_URL=https://hrntechsolutions.com/iwsha-backend/api

# ── Backend CORS (set in iwsha-backend .env on server) ──
# CORS_ORIGIN=https://www.iwshatrust.org,https://iwshatrust.org,http://localhost:5173
# SESSION_SAME_SITE=None
# SESSION_SECURE=true
# SESSION_COOKIE_DOMAIN=.hrntechsolutions.com
# Ensure storage/sessions/ is writable on the server
