# Backend API base URL (must include /api suffix, no trailing slash after /api)

# Local dev (XAMPP):
VITE_API_BASE_URL=http://localhost/schloarship-backend/api

# Production (live):
# VITE_API_BASE_URL=https://hrntechsolutions.com/iwsha-backend/api

# ── Backend CORS (set in iwsha-backend .env on server) ──
# Allow your React frontend origin(s), e.g.:
# CORS_ORIGIN=https://hrntechsolutions.com
# Or comma-separated: CORS_ORIGIN=https://hrntechsolutions.com,https://www.hrntechsolutions.com
